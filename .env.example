# ---------------------------------------------------------------------------
# audio-transcriber-obsidian-notes — configuration
#
# Copy this file to `.env` (same folder as config.py) and fill in your values.
# `.env` is gitignored. Only GEMINI_API_KEY is strictly required.
# Paths support ~, %VAR% and $VAR expansion.
# ---------------------------------------------------------------------------

# --- REQUIRED ---------------------------------------------------------------
# Google AI Studio key for Gemini transcription. Get one at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# --- Obsidian vault (where transcripts + daily notes are written) -----------
# Point this at your Obsidian vault root. Default: ~/ObsidianVault
NOTES_VAULT_ROOT=C:\Users\you\ObsidianVault
# Subfolder (inside the vault) for audio + transcripts. Default: "Audio"
# Emoji folder names work fine, e.g. "🎙 Audio".
#NOTES_AUDIO_SUBDIR=Audio
# Subfolder (inside the audio dir) for transcript markdown. Default: "transcriptions"
#NOTES_TRANSCRIPT_SUBDIR=transcriptions
# Subfolder (inside the vault) for daily notes. Default: "Daily Notes"
#NOTES_DAILY_SUBDIR=Daily Notes

# --- Optional: publish #publish-tagged notes to a static site repo ----------
# Publishing is OFF by default. It only turns on when NOTES_SITE_ROOT is set
# to a git repo below; leave it unset/commented and the publisher watcher
# never starts. (The publish step is deterministic -- no LLM is involved.)
#NOTES_SITE_ROOT=C:\Users\you\my-website
# Subfolder (inside the site repo) where note markdown is dropped.
#NOTES_SITE_NOTES_SUBDIR=src/pages/notes

# --- Optional: hotkey -------------------------------------------------------
# pynput GlobalHotKeys combo. <cmd> is the Windows / Super key. Default below.
#NOTES_HOTKEY=<cmd>+<alt>+<space>
#NOTES_HOTKEY_LABEL=Win+Alt+Space

# --- Optional: models -------------------------------------------------------
#GEMINI_MODEL_PRIMARY=gemini-3-flash-preview
#GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# --- Optional: audio + watcher tuning ---------------------------------------
#NOTES_SAMPLE_RATE=16000
#NOTES_CHANNELS=1
#NOTES_WATCHER_POLL_SECONDS=60
